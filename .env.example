# ─── GitHub OAuth App ────────────────────────────────────────────────────────
# Create one at https://github.com/settings/developers
# Set the callback URL to: https://<your-domain>/auth/callback
VITE_GITHUB_CLIENT_ID=your_github_oauth_app_client_id

# ─── Cloudflare Worker ────────────────────────────────────────────────────────
# Deploy worker/index.js to Cloudflare Workers and paste the URL here
VITE_OAUTH_WORKER_URL=https://your-worker.your-subdomain.workers.dev/callback
